# Local SQLite (libSQL) database file, relative to packages/db.
DATABASE_URL=file:../../local.db

# Allowed CORS origin (used when a web client calls the server).
CORS_ORIGIN=http://localhost:3001

# Optional: enable Claude-powered natural-language understanding for the
# assistant. When unset, the server uses a built-in rule-based parser.
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-haiku-4-5-20251001
