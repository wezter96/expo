    "@kinly/env": "*",
    "@trpc/server": "^11.18.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kinly/config": "*",
    "@types/node": "^22.13.14",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.5",
    "typescript": "^6"
  }
