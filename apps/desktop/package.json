{
  "name": "kinly-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Kinly desktop app (Electron) — end-to-end encrypted messaging on macOS, Windows, and Linux.",
  "main": "main.js",
  "scripts": {
    "build:web": "cd ../native && npx expo export --platform web --output-dir ../desktop/web-dist",
    "start": "electron .",
    "dev": "npm run build:web && electron .",
    "dist": "npm run build:web && electron-builder"
  },
  "build": {
    "appId": "app.kinly.desktop",
    "productName": "Kinly",
    "files": ["main.js", "preload.js", "web-dist/**/*"],
    "mac": { "category": "public.app-category.social-networking", "target": ["dmg"] },
    "win": { "target": ["nsis"] },
    "linux": { "target": ["AppImage", "deb"], "category": "Network" }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
