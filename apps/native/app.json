{
  "expo": {
    "name": "Kinly",
    "slug": "kinly",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kinly",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B5FA5"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Kinly uses your camera so your family can see you on video calls.",
        "NSMicrophoneUsageDescription": "Kinly uses your microphone so your family can hear you on calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B5FA5"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B5FA5",
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "aiApiKey": "",
      "aiModel": "claude-haiku-4-5-20251001"
    }
  }
}
