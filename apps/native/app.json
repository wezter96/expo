{
  "expo": {
    "name": "Kinly",
    "slug": "kinly",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kinly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A4B84"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Kinly uses your camera so your family can see you on video calls.",
        "NSMicrophoneUsageDescription": "Kinly uses your microphone so your family can hear you on calls.",
        "NSFaceIDUsageDescription": "Kinly uses Face ID to lock the app so only you can open your messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A4B84"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#1A4B84",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1A4B84"
        }
      ],
      "expo-image-picker"
    ],
    "extra": {
      "aiApiKey": "",
      "aiModel": "claude-haiku-4-5-20251001"
    }
  }
}
